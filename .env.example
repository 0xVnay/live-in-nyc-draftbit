# Base URL of the Cloudflare Worker that serves /api/places.
# - Local dev:   http://localhost:8787  (run `npm run dev` inside /worker)
# - Production:  https://<your-worker>.workers.dev  (the deployed Worker URL)
# Note: this is NOT a secret — the TicketMaster key lives only in the Worker.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8787
