# Base URL of the Cloudflare Worker that serves /api/places.
# Defaults to the deployed Worker, so `npx expo start` works with no local backend.
# To run against a local Worker (see /worker) set one of:
#   http://localhost:8787       (iOS simulator / web)
#   http://<your-LAN-IP>:8787   (physical device)
# Not a secret: the Ticketmaster key lives only in the Worker.
EXPO_PUBLIC_API_BASE_URL=https://draftbit-map.vinayleokumar.workers.dev
